{

    "build": {
        "context": ".",
        "dockerfile": "Dockerfile",
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "/opt/codespace/extensions/lynbrook-cs-0.1.0.vsix",
                "ms-python.python",
                "vscjava.vscode-java-pack",
                "oliver-ni.web-cat-vscode",
                "-GitHub.copilot",
                "-GitHub.copilot-chat",
                "-ms-azuretools.vscode-azure-github-copilot"
            ],
            "settings": {
                "files.autoSave": "off",
                "files.exclude": {
                    "Dockerfile": true,
                    "docs": true,
                    ".gitignore": true,
                    ".devcontainer.json": true,
                    "**/.git": true,
                    "**/.svn": true,
                    "**/.hg": true,
                    "**/CVS": true,
                    "**/.DS_Store": true,
                    "**/Thumbs.db": true,
                    "bats": true,
                    "fswatch": true
                },
                "java.server.launchMode": "Standard",
                "redhat.telemetry.enabled": false,
                "web-CAT.snarfURLs": [
                    "http://205.173.41.10/pythonsnarf/snarf.xml",
                    "http://205.173.41.10/javasnarf/snarf.xml",
                    "http://205.173.41.10/apcssnarf/snarf.xml"
                ],
                "web-CAT.submitURLs": [
                    "http://205.173.41.10/Web-CAT/WebObjects/Web-CAT.woa/wa/assignments/eclipse"
                ]
            }
        }
    },
    
    "workspaceFolder": "/app",
    "workspaceMount": "source=.,target=/app,type=bind", // create bind for /app in dockerfile
    "remoteUser": "root", // default user, need to create other users (students) and mount to /home
    // RUN useradd -r -m appuser (-m creates /home directory)
    // USER appuser (to run instructions in the new user)
    "postCreateCommand": "/usr/local/bin/gitwatch.sh -l 15 -r origin -b main /app"

}
