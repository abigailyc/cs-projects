{

    "build": {
        "context": ".",
        "dockerfile": "Dockerfile"
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "/opt/codespace/extensions/lynbrook-cs-0.1.0.vsix",
                "ms-python.python",
                "vscjava.vscode-java-pack",
                "oliver-ni.web-cat-vscode",
                "-GitHub.copilot",
                "-GitHub.copilot-chat",
                "-ms-azuretools.vscode-azure-github-copilot"
            ],
            "settings": {
                "files.autoSave": "afterDelay",
                "files.autoSaveDelay": 1000,
                "files.exclude": {
                    "Dockerfile": true,
                    "docs": true,
                    ".gitignore": true,
                    ".devcontainer.json": true,
                    "**/.git": true,
                    "**/.svn": true,
                    "**/.hg": true,
                    "**/CVS": true,
                    "**/.DS_Store": true,
                    "**/Thumbs.db": true,
                    "bats": true,
                    "fswatch": true,
                    ".autosave.sh": true
                },
                "java.server.launchMode": "Standard",
                "redhat.telemetry.enabled": false,
                "web-CAT.snarfURLs": [
                    "http://205.173.41.10/pythonsnarf/snarf.xml",
                    "http://205.173.41.10/javasnarf/snarf.xml",
                    "http://205.173.41.10/apcssnarf/snarf.xml"
                ],
                "web-CAT.submitURLs": [
                    "http://205.173.41.10/Web-CAT/WebObjects/Web-CAT.woa/wa/assignments/eclipse"
                ]
            }
        }
    },

    "image": "ghcr.io/markpatterson27/codespaces-vnc-image:universal",
    "forwardPorts": [6080],
    "portsAttributes": {
        "6080": {
            "label": "noVNC Viewer",
            "onAutoForward": "openBrowser"
        }
    },
    
    "workspaceFolder": "/app",
    "workspaceMount": "source=.,target=/app,type=bind", // create bind for /app in dockerfile
    "remoteUser": "root", // default user, need to create other users (students) and mount to /home
    // RUN useradd -r -m appuser (-m creates /home directory)
    // USER appuser (to run instructions in the new user)
    "postStartCommand": "nohup bash ./autosave.sh >/tmp/autosave.log 2>&1"
    // to ensure working, run "ps auxww | grep autosave.sh" and "tail -f /tmp/autosave.log"
}
